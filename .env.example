# Supabase — publishable (safe for browser and NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only secret
# CRITICAL: NEVER use NEXT_PUBLIC_ prefix here.
# This key bypasses RLS entirely and must NEVER reach the browser or be logged.
# Lives only in Edge Function secrets and .env.local (gitignored).
SUPABASE_SERVICE_ROLE_KEY=

# Worker authentication — used by POST /api/worker/run to verify the scheduler caller.
# CRITICAL: keep this server-only. Set in your deployment environment, never in code.
WORKER_RUN_SECRET=

# AI provider (Sprint 6.1) — server-only secret for the call_ai workflow step.
# CRITICAL: NEVER use NEXT_PUBLIC_ prefix. Read only in lib/ai/provider.ts; never
# logged, returned, or persisted. If unset: dev/test uses a deterministic mock;
# production fails closed (the AI step errors and the run is recoverable).
OPENAI_API_KEY=

# AI agent identity (Sprint 6.3) — used as the NOT-NULL agent_user_id when the
# call_ai step writes agent_activity. OPTIONAL: if unset, the step resolves a
# seeded role='agent' user in the org (migration 025). Set this to pin a specific
# agent user UUID. Not a secret, but server-only (never NEXT_PUBLIC).
AI_AGENT_USER_ID=

# AI session namespace (Sprint 6.3) — OPTIONAL label recorded in agent_activity
# metadata. The session_id itself is derived deterministically from the
# workflow_run_id (or background_job_id), not from this value.
AI_AGENT_SESSION_NAMESPACE=
